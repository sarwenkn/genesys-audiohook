DEBUG=false
GENESYS_API_KEY=********************
SUPPORTED_LANGUAGES=es-ES,it-IT,fr-FR,de-DE,ja-JP,zu-ZA,ms-MY
GENESYS_ORG_ID=<your_gc_org_id>
OPENAI_API_KEY=********************
OPENAI_SPEECH_MODEL=gpt-4o-transcribe
DEFAULT_SPEECH_PROVIDER=elevenlabs

# ElevenLabs Scribe v2 (streaming STT)
ELEVENLABS_API_KEY=********************
ELEVENLABS_SCRIBE_WS_URL=wss://<your_elevenlabs_scribe_ws_endpoint>
# Optional: JSON string sent on connect. Use {language} placeholder if needed.
# ELEVENLABS_SCRIBE_START_MESSAGE_JSON={"type":"start","language":"{language}","sample_rate":8000,"encoding":"pcm_s16le"}
ELEVENLABS_SCRIBE_STREAM_MODE=binary

# Optional providers
GOOGLE_SPEECH_MODEL=chirp_2
GOOGLE_CLOUD_PROJECT=<your_google_cloud_project>
GOOGLE_APPLICATION_CREDENTIALS=********************
GOOGLE_TRANSLATION_MODEL=gemini-2.0-flash-001
GEMINI_API_KEY=********************

# DAISY push
DAISY_BASE_URL=https://<your-daisy-host>
DAISY_UPDATE_PATH=/agent-assist/update
DAISY_API_KEY=********************
DAISY_TIMEOUT_SECS=2.0
DAISY_MAX_RETRIES=2
