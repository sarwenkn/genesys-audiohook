DEBUG=false

# Optional: temporary debug UI (exposed at /debug and streams events via /debug/ws)
# Set a strong random token and access: https://<domain>/debug?token=<token>
# DEBUG_UI_TOKEN=REPLACE_ME
# Optional: save received audio to WAV files in DEBUG_AUDIO_DIR
# DEBUG_SAVE_AUDIO=true
# DEBUG_AUDIO_DIR=debug_audio
GENESYS_API_KEY=********************
SUPPORTED_LANGUAGES=es-ES,it-IT,fr-FR,de-DE,ja-JP,zu-ZA,ms-MY
GENESYS_ORG_ID=<your_gc_org_id>
# If your Genesys AudioHook config rejects transcript event messages, set this false.
# GENESYS_SEND_TRANSCRIPT_EVENTS=false
OPENAI_API_KEY=********************
OPENAI_SPEECH_MODEL=gpt-4o-transcribe
DEFAULT_SPEECH_PROVIDER=elevenlabs

# ElevenLabs Scribe v2 (streaming STT)
ELEVENLABS_API_KEY=********************
# Optional override; default points to ElevenLabs realtime STT endpoint.
# ELEVENLABS_SCRIBE_WS_URL=wss://api.elevenlabs.io/v1/speech-to-text/realtime?model_id=scribe_v2_realtime&commit_strategy=vad&audio_format=pcm_16000
# This repo sends JSON `input_audio_chunk` messages with base64 audio by default.
ELEVENLABS_SCRIBE_STREAM_MODE=json_base64
# Resample Genesys 8kHz audio to 16kHz for ElevenLabs (recommended)
ELEVENLABS_SCRIBE_TARGET_SAMPLE_RATE=16000

# Optional providers
GOOGLE_SPEECH_MODEL=chirp_2
GOOGLE_CLOUD_PROJECT=<your_google_cloud_project>
GOOGLE_APPLICATION_CREDENTIALS=********************
GOOGLE_TRANSLATION_MODEL=gemini-2.0-flash-001
GEMINI_API_KEY=********************

# DAISY push
DAISY_BASE_URL=https://<your-daisy-host>
DAISY_UPDATE_PATH=/agent-assist/update
DAISY_API_KEY=********************
DAISY_TIMEOUT_SECS=2.0
DAISY_MAX_RETRIES=2
