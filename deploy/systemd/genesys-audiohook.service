[Unit]
Description=Genesys AudioHook WebSocket Server
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/genesys-audiohook
EnvironmentFile=/opt/genesys-audiohook/.env
ExecStart=/opt/genesys-audiohook/.venv/bin/python /opt/genesys-audiohook/main.py
Restart=always
RestartSec=2

# Basic hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true

[Install]
WantedBy=multi-user.target

